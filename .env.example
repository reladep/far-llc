# ─────────────────────────────────────────────────────────────────────────────
# Visor Index — Environment Variables
# Copy to .env.local for development. For production, set these in Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
# Database, auth, and storage. All are required to run the app.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Admin key — bypasses Row-Level Security. Only used in server-side API routes.
# NEVER expose with NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Stripe (required for paid tiers) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe price IDs for each tier — see pricing page
STRIPE_PRICE_TRIAL=price_...
STRIPE_PRICE_CONSUMER=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Resend (required for transactional email) ────────────────────────────────
# Used by: /api/contact, /api/consultation, /api/alerts/digest
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Cloudflare Turnstile (optional, recommended) ─────────────────────────────
# CAPTCHA for public forms. If TURNSTILE_SECRET_KEY is unset, validation is skipped.
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Cron jobs (required) ─────────────────────────────────────────────────────
# Shared secret used by Vercel cron → /api/cron/*, /api/alerts/digest, /api/alerts/detect.
# Generate a random string: `openssl rand -hex 32`
CRON_SECRET=

# ── Sentry observability (optional) ──────────────────────────────────────────
# Server-side error tracking. Client-side is separate so it can be public.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Site URL (used in emails + sitemap) ──────────────────────────────────────
# Overrides the default `https://visorindex.com` in email links. Set to the
# current deployment URL in preview environments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Upstash Redis (optional — production rate limiting) ──────────────────────
# Enables global rate limiting across all serverless instances.
# If unset, falls back to per-instance in-memory limiter (fine for dev).
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
